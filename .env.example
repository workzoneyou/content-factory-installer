# ============================================================
# Content Factory — параметры установки
# Скопируйте в .env и заполните. Пустые пароли/ключи сгенерируются автоматически.
# ============================================================

# ── Бренд ──────────────────────────────────────────────────
BRAND=cyberfactory                    # slug (латиница, без пробелов): имена контейнеров, сеть, тема, /opt/<BRAND>
BRAND_NAME=Content Factory            # видимое имя (Author темы, автор блога)
BRAND_URL=https://example.com         # сайт бренда (Author URI)

# ── Домены (оба поддомена должны A-записью смотреть на IP сервера) ──
BLOG_DOMAIN=blog.example.com
N8N_DOMAIN=n8n.example.com
SSL_EMAIL=admin@example.com           # e-mail для аккаунта Let's Encrypt

# ── WordPress ──────────────────────────────────────────────
SITE_NAME=Блог
WP_ADMIN_USER=admin
WP_ADMIN_EMAIL=admin@example.com
WP_ADMIN_PASSWORD=                    # пусто → сгенерится
DB_NAME=wordpress
DB_USER=wp
DB_PASSWORD=                          # пусто → сгенерится
DB_ROOT_PASSWORD=                     # пусто → сгенерится
YANDEX_METRIKA_ID=                    # ID счётчика Яндекс.Метрики (опц.)

# ── Автор блога (карточка пользователя WP) ─────────────────
AUTHOR_DISPLAY=Имя Фамилия
AUTHOR_BIO=Краткое человеческое описание автора без иишности.
AUTHOR_SITE=                          # https://... (сайт автора)
AUTHOR_VK=                            # https://vk.com/...
AUTHOR_TELEGRAM=                      # https://t.me/...
AUTHOR_YOUTUBE=                       # https://youtube.com/...

# ── n8n ────────────────────────────────────────────────────
N8N_DB_PASSWORD=                      # пусто → сгенерится
N8N_ENCRYPTION_KEY=                   # пусто → сгенерится (важно: не менять после первого запуска!)
TZ=Europe/Moscow

# ── n8n: воркфлоу, Google-таблица, API-ключи ───────────────
# В .env НЕ хранятся. n8n ставится ПУСТЫМ; воркфлоу импортируются через UI,
# а Google Sheets/Drive и ключи OpenRouter/KIE/Perplexity заводятся в
# n8n → Credentials уже после установки (см. README).
