# ============================================================
# Content Factory — параметры установки
# setup.sh задаёт их вопросами и сам пишет .env. Этот файл — справочник.
# Пустые пароли/ключи генерируются автоматически.
# ============================================================

# ── Спрашивается при установке (нужно для инфраструктуры) ───
BLOG_DOMAIN=blog.example.com          # домен блога (A-запись → IP сервера)
N8N_DOMAIN=n8n.example.com            # домен n8n   (A-запись → IP сервера)
SSL_EMAIL=admin@example.com           # e-mail для аккаунта Let's Encrypt
WP_ADMIN_USER=admin                   # логин WP-админа
WP_ADMIN_EMAIL=admin@example.com      # e-mail WP-админа

# ── Фиксировано в setup.sh (не спрашивается) ───────────────
BRAND=firsanov                        # имена контейнеров/сети/папок И папка темы
                                      # (CSS/шрифты темы жёстко ждут /wp-content/themes/firsanov/)
BRAND_URL=https://blog.example.com    # = https://BLOG_DOMAIN
SITE_NAME=Блог                        # заголовок сайта — меняется в WP: Настройки → Общие
YANDEX_METRIKA_ID=                    # Метрика подключается в WP после установки

# ── Генерируется автоматически ─────────────────────────────
WP_ADMIN_PASSWORD=                    # пусто → сгенерится
DB_NAME=wordpress
DB_USER=wp
DB_PASSWORD=                          # пусто → сгенерится
DB_ROOT_PASSWORD=                     # пусто → сгенерится
N8N_DB_PASSWORD=                      # пусто → сгенерится
N8N_ENCRYPTION_KEY=                   # пусто → сгенерится (важно: не менять после первого запуска!)
TZ=Europe/Moscow

# ── Настраивается в самом WordPress ПОСЛЕ установки ─────────
# • Название сайта — Настройки → Общие
# • Автор: имя, описание, ВК/Telegram/RuTube/TenChat — Пользователи → профиль
# • Метрика — в настройках плагина

# ── n8n: воркфлоу, Google-таблица, API-ключи ───────────────
# В .env НЕ хранятся. n8n ставится ПУСТЫМ; воркфлоу импортируются через UI,
# а Google Sheets/Drive и ключи OpenRouter/KIE/Perplexity заводятся в
# n8n → Credentials уже после установки (см. README).
